+        auto push_if_valid = [&](std::string const &id) {
+            if (find_action(id) && std::find(state->favorites.begin(), state->favorites.end(), id) == state->favorites.end()) {
+                state->favorites.push_back(id);
+            }
+        };
+
+        if (!stored.empty()) {
+            std::stringstream stream(stored.raw());
+            std::string id;
+            while (std::getline(stream, id, ';')) {
+                push_if_valid(id);
+            }
+        }
+
+        if (state->favorites.empty()) {
+            for (auto const &id : state->default_favorites) {
+                push_if_valid(id);
+            }
+        }
+    };
