+    auto serialize_favorites = [state]() {
+        std::ostringstream out;
+        for (std::size_t i = 0; i < state->favorites.size(); ++i) {
+            if (i) {
+                out << ';';
+            }
+            out << state->favorites[i];
+        }
+        return out.str();
+    };
