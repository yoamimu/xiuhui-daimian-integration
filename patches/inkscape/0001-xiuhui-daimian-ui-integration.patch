+        _titlebar.append(_restore_button);
+
+        setup_handle(_top_left, "nwse-resize", ResizeTop | ResizeLeft);
+        setup_handle(_top, "ns-resize", ResizeTop);
+        setup_handle(_top_right, "nesw-resize", ResizeTop | ResizeRight);
+        setup_handle(_left, "ew-resize", ResizeLeft);
+        setup_handle(_right, "ew-resize", ResizeRight);
+        setup_handle(_bottom_left, "nesw-resize", ResizeBottom | ResizeLeft);
+        setup_handle(_bottom, "ns-resize", ResizeBottom);
