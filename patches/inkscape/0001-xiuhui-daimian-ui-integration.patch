+
+private:
+    static void install_css()
+    {
+        static Glib::RefPtr<Gtk::CssProvider> provider;
+        if (!provider) {
+            provider = Gtk::CssProvider::create();
+            provider->load_from_data(floating_panel_css);
+            if (auto display = Gdk::Display::get_default()) {
+                Gtk::StyleContext::add_provider_for_display(display, provider, GTK_STYLE_PROVIDER_PRIORITY_APPLICATION + 20);
+            }
+        }
+    }
+
+    void setup_drag(Gtk::Widget &widget)
+    {
+        auto click = Gtk::GestureClick::create();
+        click->set_button(1);
+        click->set_propagation_phase(Gtk::PropagationPhase::CAPTURE);
+        click->signal_pressed().connect([this, target = &widget](int, double start_x, double start_y) {
+            _dragging = true;
+            _drag_moved = false;
+            _drag_press_panel_x = _x;
+            _drag_press_panel_y = _y;
+            _drag_pointer_offset_x = FLOATING_PANEL_EDGE + start_x;
+            _drag_pointer_offset_y = FLOATING_PANEL_EDGE + start_y;
+            if (auto parent = get_parent()) {
+                auto start = target->compute_point(*parent, Gdk::Graphene::Point(start_x, start_y));
+                if (start) {
+                    _drag_pointer_offset_x = start->get_x() - _x;
+                    _drag_pointer_offset_y = start->get_y() - _y;
+                }
+            }
+        });
+        click->signal_released().connect([this](int, double, double) {
+            _dragging = false;
+        });
+        widget.add_controller(click);
+
+        auto motion = Gtk::EventControllerMotion::create();
+        motion->set_propagation_phase(Gtk::PropagationPhase::CAPTURE);
+        motion->signal_motion().connect([this, target = &widget](double x, double y) {
+            if (!_dragging) {
+                return;
+            }
+            if (auto parent = get_parent()) {
+                auto point = target->compute_point(*parent, Gdk::Graphene::Point(x, y));
+                if (!point) {
+                    return;
+                }
+                auto next_x = point->get_x() - _drag_pointer_offset_x;
+                auto next_y = point->get_y() - _drag_pointer_offset_y;
+                if (std::abs(next_x - _drag_press_panel_x) > 3 || std::abs(next_y - _drag_press_panel_y) > 3) {
+                    _drag_moved = true;
+                }
+                move_to(next_x, next_y);
+            }
+        });
+        widget.add_controller(motion);
+    }
+
+    void setup_handle(Gtk::Box &handle, char const *cursor, int edges)
+    {
+        handle.set_cursor(cursor);
+
+        auto drag = Gtk::GestureDrag::create();
+        drag->set_propagation_phase(Gtk::PropagationPhase::CAPTURE);
+        drag->signal_drag_begin().connect([this](double, double) {
+            _resize_start_x = _x;
+            _resize_start_y = _y;
+            _resize_start_width = _width;
+            _resize_start_height = _height;
+        });
+        drag->signal_drag_update().connect([this, edges](double dx, double dy) {
+            if (std::abs(dx) > 3 || std::abs(dy) > 3) {
+                _drag_moved = true;
+            }
+            resize_from(edges, dx, dy);
+        });
+        handle.add_controller(drag);
+    }
+
+    void apply_position()
+    {
+        if (_fixed_parent) {
+            _fixed_parent->move(*this, _x, _y);
+        } else {
+            set_margin_start(static_cast<int>(_x));
+            set_margin_top(static_cast<int>(_y));
+        }
+    }
+
+    void set_handles_visible(bool visible)
+    {
+        _top_left.set_visible(visible);
+        _top.set_visible(visible);
+        _top_right.set_visible(visible);
+        _left.set_visible(visible);
+        _right.set_visible(visible);
+        _bottom_left.set_visible(visible);
+        _bottom.set_visible(visible);
+        _bottom_right.set_visible(visible);
+    }
+
+    void set_minimized(bool minimized)
+    {
+        if (_minimized == minimized) {
+            return;
+        }
+
+        _minimized = minimized;
+        if (minimized) {
+            _expanded_width = _width;
+            _expanded_height = _height;
+            _x = std::max(0.0, _x + _expanded_width - FLOATING_PANEL_MINI_SIZE);
+            _width = FLOATING_PANEL_MINI_SIZE;
+            _height = FLOATING_PANEL_MINI_SIZE;
+            add_css_class("inkstitch-floating-panel-mini");
+        } else {
+            _x = std::max(0.0, _x + _width - _expanded_width);
+            _width = _expanded_width;
+            _height = _expanded_height;
+            remove_css_class("inkstitch-floating-panel-mini");
+        }
+
+        set_handles_visible(!minimized);
+        _title_label.set_visible(!minimized);
+        _collapse_button.set_visible(_collapse_enabled && !minimized);
+        _restore_button.set_visible(minimized);
+        _content.set_visible(!minimized);
+        _titlebar.set_size_request(minimized ? FLOATING_PANEL_MINI_SIZE : -1,
+                                   minimized ? FLOATING_PANEL_MINI_SIZE : 24);
+        _titlebar.set_halign(minimized ? Gtk::Align::CENTER : Gtk::Align::FILL);
+        _titlebar.set_hexpand(!minimized);
+        set_size_request(_width, _height);
+        apply_position();
+    }
+
+    void move_to(double x, double y)
+    {
+        if (_fixed_parent) {
+            _x = std::max(0.0, x);
+            _y = std::max(0.0, y);
+        } else {
+            auto [max_x, max_y] = max_position_for(_width, _height);
+            _x = std::clamp(x, 0.0, max_x);
+            _y = std::clamp(y, 0.0, max_y);
+        }
+        if (_fixed_parent) {
+            _fixed_parent->move(*this, _x, _y);
+        } else {
+            apply_position();
+        }
+    }
+
+    void resize_from(int edges, double dx, double dy)
+    {
+        auto x = _resize_start_x;
+        auto y = _resize_start_y;
+        auto width = _resize_start_width;
+        auto height = _resize_start_height;
+
+        if (edges & ResizeLeft) {
+            x = _resize_start_x + dx;
+            width = _resize_start_width - dx;
+            if (width < _min_width) {
+                x -= _min_width - width;
+                width = _min_width;
+            }
+        } else if (edges & ResizeRight) {
+            width = _resize_start_width + dx;
+        }
+
+        if (edges & ResizeTop) {
+            y = _resize_start_y + dy;
+            height = _resize_start_height - dy;
+            if (height < _min_height) {
+                y -= _min_height - height;
+                height = _min_height;
+            }
+        } else if (edges & ResizeBottom) {
+            height = _resize_start_height + dy;
+        }
+
+        width = std::max(width, static_cast<double>(_min_width));
+        height = std::max(height, static_cast<double>(_min_height));
+
+        if (!_fixed_parent) {
+            auto parent = get_parent();
+            if (parent) {
+                auto max_width = std::max(_min_width, parent->get_width() - static_cast<int>(x));
+                auto max_height = std::max(_min_height, parent->get_height() - static_cast<int>(y));
+                width = std::min(width, static_cast<double>(max_width));
+                height = std::min(height, static_cast<double>(max_height));
+            }
+        }
+
+        _x = std::max(0.0, x);
+        _y = std::max(0.0, y);
+        _width = static_cast<int>(width);
+        _height = static_cast<int>(height);
+
+        if (_fixed_parent) {
+            _fixed_parent->move(*this, _x, _y);
+        } else {
+            apply_position();
+        }
+        set_size_request(_width, _height);
+    }
+
+    std::pair<double, double> max_position_for(int width, int height) const
+    {
+        if (_fixed_parent) {
+            return {
+                static_cast<double>(std::max(0, _fixed_parent->get_width() - width)),
+                static_cast<double>(std::max(0, _fixed_parent->get_height() - height)),
+            };
+        } else if (auto parent = get_parent()) {
+            return {
+                static_cast<double>(std::max(0, parent->get_width() - width)),
+                static_cast<double>(std::max(0, parent->get_height() - height)),
+            };
+        }
+        return {10000.0, 10000.0};
+    }
+
+    Gtk::Box _top_left;
+    Gtk::Box _top;
+    Gtk::Box _top_right;
+    Gtk::Box _left;
+    Gtk::Box _right;
+    Gtk::Box _bottom_left;
+    Gtk::Box _bottom;
+    Gtk::Box _bottom_right;
+    Gtk::Box _titlebar;
+    Gtk::Box _content;
+    Gtk::Label _title_label;
+    Gtk::Image _collapse_icon;
+    Gtk::Label _restore_label;
+    Gtk::Button _collapse_button;
+    Gtk::Button _restore_button;
+    Gtk::Fixed *_fixed_parent = nullptr;
+
+    double _x = 0;
+    double _y = 0;
+    int _width = 0;
+    int _height = 0;
+    int _min_width = 0;
+    int _min_height = 0;
+    int _expanded_width = 0;
+    int _expanded_height = 0;
+    bool _collapse_enabled = false;
+    bool _minimized = false;
+    bool _dragging = false;
+    bool _drag_moved = false;
+    double _drag_press_panel_x = 0;
+    double _drag_press_panel_y = 0;
+    double _drag_pointer_offset_x = 0;
+    double _drag_pointer_offset_y = 0;
+    double _resize_start_x = 0;
+    double _resize_start_y = 0;
+    double _resize_start_width = 0;
+    double _resize_start_height = 0;
+};
