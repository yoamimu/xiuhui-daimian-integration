diff --git a/lib/i18n.py b/lib/i18n.py
index b2a2b00..6605fc9 100644
--- a/lib/i18n.py
+++ b/lib/i18n.py
@@ -7,6 +7,7 @@ import gettext
 import os
 from typing import Callable, Tuple
 
+from .i18n_zh_cn import translate_zh_cn
 from .utils import cache, get_resource_dir
 
 # Use N_ to mark a string for translation but _not_ immediately translate it.
@@ -18,13 +19,41 @@ def N_(message: str) -> str:
     return message
 
 
+def _normalize_language(language: str) -> str:
+    return language.split('.')[0].split('@')[0].replace('-', '_').lower()
+
+
+def _uses_simplified_chinese(languages=None) -> bool:
+    languages = languages or get_languages()
+    for language in languages:
+        normalized = _normalize_language(language)
+        if normalized in ("zh", "zh_cn", "zh_hans", "chinese_china"):
+            return True
+    return False
+
+
+def _with_zh_cn_fallback(gettext_func: Callable[[str], str]) -> Callable[[str], str]:
+    def gettext_with_fallback(message: str) -> str:
+        translated = gettext_func(message)
+        local_translation = translate_zh_cn(message)
+        if local_translation is not None:
+            return local_translation
+        if translated == message:
+            return message
+        return translated
+
+    return gettext_with_fallback
+
+
 def localize(languages=None) -> Tuple[Callable[[str], str], gettext.NullTranslations]:
     locale_dir = get_resource_dir('locales')
 
     global translation, _
 
-    translation = gettext.translation("inkstitch", locale_dir, fallback=True)
+    translation = gettext.translation("inkstitch", locale_dir, languages=languages, fallback=True)
     _ = translation.gettext
+    if _uses_simplified_chinese(languages):
+        _ = _with_zh_cn_fallback(_)
     return (_, translation)
 
 
