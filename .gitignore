# Local build and release output
/build/
/dist/
/release/*.exe
/release/*.msi
/release/*.zip
/release/*.7z
/release/*.tar
/release/*.tar.gz

# Temporary/cache output
/.tmp_system/
/.cache/
/.pip-cache/
/.pycache/
__pycache__/
*.pyc

# Local machine metadata
/.local/
/.env
*.log

# Handoff documents for one-off AI sessions on other machines (not part of the project)
/HANDOFF_*.md

# Cross-machine snapshot dropoff (mac AI hands patches/diffs back through this)
/mac-build-snapshot/

# macOS resource-fork / metadata files that leak through SMB / USB copies
._*
.DS_Store

